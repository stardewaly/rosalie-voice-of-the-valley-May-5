"stardewaly.rosalie_FlareUpCT": "{{i18n:Harvey.Flareup_{{ Random: 1, 2 }} }}",




//Random ROsalie Dialogue
   "HarveyOnRosalie1": "Rosalie has been making great progress lately. #$b# She's starting to open up more, which is wonderful to see.$h",
          "HarveyOnRosalie2": "You know, sometimes all it takes is a friendly face to help someone feel comfortable. #$b# Thank you for being there for Rosalie.$2",
          "HarveyOnRosalie3": "Have you met Gus' niece, Rosalie? #$b# Her aesthetic is... quite unique, huh?$h #$e#%Harvey adjusts his tie, his cheeks slightly flushed.",
          "HarveyOnRosalie4": "It's important for Rosalie to have friends like you. #$b# Social connections are vital for mental health.$2",
          "HarveyOnRosalie5": "I usually take the mornings after opening the clinic to organize my paperwork, #$b# But Rosalie is my one exception. #$e# It's nice having a friendly face to see first thing in the morning...",


//2 Hearts//

"HarveyOnRosalie2Hearts1": "It may be strange, or even unconventional, but I do worry for my patients. #$b# Someone Rosalie's age shouldn't be here as often as she is...$s",
          "HarveyOnRosalie2Hearts2": "Rosalie has been dropping off coffee for me for some mornings. #$b# It's a small gesture, but it means a lot. And it means she can leave the house.$h",
         

//4 Hearts//

          "HarveyOnRosalie4Hearts1": "You know, Rose was a bit shy to me at first, but I like to consider her to be a friend now.$h #$e#%Harvey smiles warmly.",
             "HarveyOnRosalie4Hearts2": "I think Rosalie is starting to trust me more. #$b# Building that trust is crucial for her recovery.$h",
          "HarveyOnRosalie4Hearts3": "Have you seen Rosalie around lately? #$b# She's been looking a bit brighter these days.$h",


    //6 Hearts//
          "HarveyOnRosalie6Hearts1": "Rose has been dropping off coffee for me a lot lately, even when she doesn't have appointments.$h #$e# Do... Do you think it means anything?$7",
          "HarveyOnRosalie6Hearts2": "You know, I tried to encourage Rose to come to aerobics class with me... #$b# She... didn't seem too interested.$s",

          //8 Hearts (player NOT dating Harvey, HARVEY CRUSH)//
          "HarveyOnRosalie8Hearts1": "Rose seems to be doing much better lately. #$b# I think having friends like you has really helped her.$h",
            "HarveyOnRosalie8Hearts2": "Rose has been flaring up less lately!$h #$b# It's not perminent, but I like to think positively.$h",
